# Copy to .env.prod, then run:  make deploy   ->   http://localhost
# Defaults below work for LOCAL Docker review out of the box (only Docker needed).
# For a public domain, change the lines marked "PUBLIC:".

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0
# PUBLIC: add your domain, e.g. localhost,127.0.0.1,yourdomain.uz
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# PUBLIC: https://yourdomain.uz
CSRF_TRUSTED_ORIGINS=http://localhost
USE_X_FORWARDED_PROTO=1

# Create demo users (alice / bob / admin) on first boot. Set 0 to disable.
SEED_DEMO=1

# --- Database (host = compose service name; keep as-is for Docker) ---
DB_NAME=hamyon
DB_USER=hamyon
DB_PASSWORD=change-me-db-password
DB_HOST=db
DB_PORT=5432

# --- Redis / Celery (host = compose service name) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# --- Secrets ---
OTP_PEPPER=change-me-otp-pepper
QR_JWT_SECRET=change-me-at-least-32-bytes-long-secret-string

# PUBLIC: https://yourdomain.uz  (used for links in exported files / messages)
EXPORT_BASE_URL=http://localhost

# --- Telegram (leave empty for console-imitation mode) ---
TELEGRAM_OTP_BOT_TOKEN=
TELEGRAM_PUSH_BOT_TOKEN=
