# Copy to .env.prod and fill in real values, then: make deploy
# Подсказка по генерации секретов (на сервере):
#   openssl rand -base64 48   # для SECRET_KEY / DB_PASSWORD
#   openssl rand -hex 32      # для OTP_PEPPER / QR_JWT_SECRET

# --- Django ---
DJANGO_SECRET_KEY=CHANGE-ME-to-a-long-random-string
DJANGO_DEBUG=0
# За Cloudflare Tunnel сюда ставится хост туннеля (например myapp.example.com).
# Для временного quick-туннеля (адрес меняется) можно поставить *.
DJANGO_ALLOWED_HOSTS=yourdomain.example.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.example.com
USE_X_FORWARDED_PROTO=1

# Create demo users (alice / bob / admin) on first boot. Set 0 для реальной эксплуатации.
SEED_DEMO=1
# Echo OTP в /api/demo/last-otp/ — нужно для демо-UI без реального Telegram-бота.
# Для реальной эксплуатации → 0 (и подключить TELEGRAM_OTP_BOT_TOKEN ниже).
OTP_DEMO_ECHO=1

# --- Database (must match the db container; host = service name) ---
DB_NAME=hamyon
DB_USER=hamyon
DB_PASSWORD=CHANGE-ME-db-password
DB_HOST=db
DB_PORT=5432

# --- Redis / Celery (host = service name) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# --- Secrets ---
OTP_PEPPER=CHANGE-ME-otp-pepper
QR_JWT_SECRET=CHANGE-ME-at-least-32-bytes-long-secret

# --- Links in exported files / messages ---
EXPORT_BASE_URL=https://yourdomain.example.com

# --- Telegram (leave empty for console-imitation mode) ---
TELEGRAM_OTP_BOT_TOKEN=
TELEGRAM_PUSH_BOT_TOKEN=

# --- Публичный домен + HTTPS (Caddy) ---
# Домен, на который Caddy выпишет HTTPS-сертификат Let's Encrypt и будет принимать
# трафик (напр. hamyon.duckdns.org). Должен A-записью указывать на IP сервера,
# порты 80/443 должны быть открыты.
SITE_ADDRESS=hamyon.duckdns.org

# --- Cloudflare Tunnel (опция, profile "tunnel" — по умолчанию выключен) ---
# Токен named-туннеля из дашборда Cloudflare (Zero Trust -> Networks -> Tunnels).
# Нужен домен в аккаунте Cloudflare для постоянного публичного hostname.
# Оставь пустым, если используешь временный quick-туннель (см. docker-compose.prod.yml).
CF_TUNNEL_TOKEN=
