# Copy to .env.prod and fill in real values, then: make deploy

# --- Django ---
DJANGO_SECRET_KEY=CHANGE-ME-to-a-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=yourdomain.uz,www.yourdomain.uz
CSRF_TRUSTED_ORIGINS=https://yourdomain.uz,https://www.yourdomain.uz
USE_X_FORWARDED_PROTO=1

# Create demo users (alice / bob / admin) on first boot. Set 0 to disable.
SEED_DEMO=1

# --- Database (must match the db container; host = service name) ---
DB_NAME=hamyon
DB_USER=hamyon
DB_PASSWORD=CHANGE-ME-db-password
DB_HOST=db
DB_PORT=5432

# --- Redis / Celery (host = service name) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# --- Secrets ---
OTP_PEPPER=CHANGE-ME-otp-pepper
QR_JWT_SECRET=CHANGE-ME-at-least-32-bytes-long-secret

# --- Links in exported files / messages ---
EXPORT_BASE_URL=https://yourdomain.uz

# --- Telegram (leave empty for console-imitation mode) ---
TELEGRAM_OTP_BOT_TOKEN=
TELEGRAM_PUSH_BOT_TOKEN=
