# Copy to .env and adjust. Defaults work with `docker compose up -d`.

DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=1

DB_NAME=hamyon
DB_USER=hamyon
DB_PASSWORD=hamyon
DB_HOST=localhost
DB_PORT=5544

REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1

# Secrets for OTP hashing and dynamic QR JWT signing.
OTP_PEPPER=change-me-too
QR_JWT_SECRET=change-me-as-well

# Leave empty to run Telegram in console-imitation mode.
# Two separate bots on purpose: OTP and push notifications share no code path.
TELEGRAM_OTP_BOT_TOKEN=
TELEGRAM_PUSH_BOT_TOKEN=

EXPORT_BASE_URL=http://localhost:8000
